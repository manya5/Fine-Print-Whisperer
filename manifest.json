{
  "manifest_version": 3,
  "name": "Fine Print Whisperer",
  "version": "1.1",
  "description": "Auto-detect Terms of Service and instantly surface red flags in plain English, with built-in AI — no setup required.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://fine-print-whisperer.fine-print-whisperer.workers.dev/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["overlay.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

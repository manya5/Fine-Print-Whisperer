{
  "manifest_version": 3,
  "name": "Fine Print Whisperer",
  "version": "1.0",
  "description": "Auto-detect Terms of Service and instantly surface red flags using free on-device AI and regex.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["overlay.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
